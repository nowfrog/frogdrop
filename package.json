{
  "name": "frogdrop",
  "version": "1.1.0",
  "productName": "FROGDROP",
  "main": "main.js",
  "description": "Drop your listings everywhere",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "dist-installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.frogdrop.app",
    "productName": "FROGDROP",
    "win": {
      "target": [
        "portable"
      ],
      "icon": "logo.png"
    },
    "portable": {
      "artifactName": "FROGDROP-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "FROGDROP-${version}-setup.exe"
    },
    "files": [
      "main.js",
      "renderer.js",
      "preload.js",
      "index.html",
      "styles.css",
      "logo.png",
      "ebay-api.js",
      "ebay-auth.js",
      "etsy-api.js",
      "etsy-auth.js",
      "fetch-categories.js",
      "CategoryIDs.csv",
      "translations/**/*",
      "node_modules/**/*",
      "!node_modules/**/README*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/test/**",
      "!node_modules/**/*.md",
      "!appdata/**",
      "!config.json",
      "!photos/**",
      "!lego-data/**",
      "!vinted-data/**",
      "!.prompt.md",
      "!.response.json",
      "!test-api.js",
      "!docs/**"
    ],
    "extraResources": [],
    "asar": false
  },
  "devDependencies": {
    "electron": "^40.7.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "electron-store": "^8.2.0",
    "node-pty": "^1.1.0"
  }
}
